# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do NOT commit real .env files with secrets)
.env
.env.local
.env.*.local
.env.production
.env.development

# python - virtual environment
backend/venv/
backend/.venv/
venv/
.venv/

# python - cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/__pycache__/

# pip/pipenv
*.egg-info/
dist/
build/
*.egg

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log
logs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
